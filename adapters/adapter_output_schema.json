{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claimtransfer.local/adapter_output_schema.json",
  "title": "ClaimTransfer normalized adapter-output row",
  "type": "object",
  "required": [
    "registry_version",
    "split",
    "task_id",
    "task_family",
    "adapter",
    "adapter_family",
    "seed",
    "evidence_object",
    "claim_type",
    "target",
    "scorer",
    "predicate"
  ],
  "properties": {
    "registry_version": {"type": "string"},
    "split": {"type": "string"},
    "task_id": {"type": "string"},
    "task_family": {"type": "string"},
    "adapter": {"type": "string"},
    "adapter_family": {"type": "string"},
    "source_kind": {"type": "string"},
    "source_file": {"type": "string"},
    "seed": {"type": ["integer", "string"]},
    "evidence_object": {"type": "string"},
    "claim_type": {"type": "string"},
    "target": {"type": ["string", "array", "object"]},
    "scorer": {"type": "string"},
    "predicate": {"type": "string"},
    "threshold": {"type": ["number", "string"]},
    "budget": {"type": ["number", "string"]},
    "rank": {"type": ["number", "string"]},
    "margin": {"type": ["number", "string"]},
    "raw_value": {"type": ["number", "string", "boolean"]},
    "selected_set": {"type": ["string", "array"]},
    "candidate_set": {"type": ["string", "array"]},
    "expression": {"type": "string"},
    "operators": {"type": ["string", "array"]},
    "expression_complexity": {"type": ["number", "string"]},
    "coefficient_error": {"type": ["number", "string"]},
    "extrapolation_error": {"type": ["number", "string"]},
    "unit_consistency": {"type": ["number", "string", "boolean"]},
    "missing_reason": {"type": "string"},
    "runtime_seconds": {"type": ["number", "string"]},
    "protocol": {"type": "string"}
  }
}
